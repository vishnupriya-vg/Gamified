{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git push origin main 2>/dev/null || true",
            "async": true,
            "statusMessage": "Pushing changes to GitHub..."
          }
        ]
      }
    ]
  }
}
